# AI Workflow Agent Environment Variables

# LLM Provider (openai or anthropic)
LLM_PROVIDER=anthropic

# Model to use
MODEL_NAME=claude-sonnet-4-20250514

# Model parameters
TEMPERATURE=0.7
MAX_TOKENS=4096

# Retry settings
MAX_RETRIES=3
RETRY_DELAY=1.0
RETRY_BACKOFF=2.0

# Human-in-the-loop settings
AUTO_APPROVE_SAFE=true
REQUIRE_APPROVAL=true

# Logging
LOG_LEVEL=INFO
ENABLE_TRACING=true

# Tool settings (optional)
# SMTP_SERVER=smtp.example.com
# SMTP_PORT=587
# EMAIL_FROM=agent@example.com
# REPORTS_DIR=./reports
# DATA_DIR=./data
# OUTPUT_DIR=./output
